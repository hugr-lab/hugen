# hugen configuration — secrets and connection details.
# Copy to .env and fill in. Non-secret defaults live in config.yaml.

HUGR_URL=http://localhost:15000

# Auth + mode detection:
# - Both HUGR_ACCESS_TOKEN and HUGR_TOKEN_URL set → REMOTE mode:
#   hub hands this process a token; whoami + config are pulled from
#   hub.db.agents using that token.
# - Either missing → LOCAL mode: hugr auth falls back to OIDC
#   discovery via {HUGR_URL}/auth/config; config is read from
#   config.yaml.

# 1. Token exchange (production / hub-managed — REMOTE mode)
# HUGR_ACCESS_TOKEN=eyJhbG...
# HUGR_TOKEN_URL=http://hub-service:8080/token

# 2. OIDC browser flow (dev — opens browser for login; LOCAL mode)
# HUGR_OIDC_ISSUER=http://localhost:8080/realms/hugr
# HUGR_OIDC_CLIENT_ID=hugr-agent

# Listener ports
HUGEN_PORT=10000
HUGEN_BASE_URL=http://localhost:10000

# Config file (relative to working directory).
HUGEN_CONFIG_FILE=config.yaml

# Operator-visible exchange folder mounted into bash-mcp as
# $SHARED_DIR. Leave commented to disable.
# HUGEN_SHARED_ROOT=${PWD}/data

# Persistent state root — read by `${HUGEN_STATE}/workspaces` in
# config.yaml (hugr-query / python-mcp WORKSPACES_ROOT) and by the
# Makefile's python-mcp-template default destination.
HUGEN_STATE=${HOME}/.hugen

# Per-spawn template the python-mcp binary copies into each session
# at the first python.run_* call. Build once via
# `make python-mcp-template` (requires uv >= 0.4.0 + Python >= 3.10
# on PATH).
HUGEN_PYTHON_TEMPLATE=${HOME}/.hugen/python-template/.venv

# Vendor directory for in-tree MCPs spawned via uvx (currently
# duckdb-mcp = vendored mcp-server-motherduck). hugen auto-sets this
# to <startup-cwd>/vendor at boot if not already in env, so launching
# from the repo root just works. Override only if your vendor tree
# lives elsewhere (e.g. shared install path).
# HUGEN_VENDOR_DIR=${PWD}/vendor

# Local LLM endpoints (LM Studio / Ollama / vLLM, OpenAI-compatible).
# Used by config.yaml local_db.models[].path expansion.
LLM_LOCAL_URL=http://localhost:1234/v1/chat/completions
EMBED_LOCAL_URL=http://localhost:1234/v1/embeddings

# Cloud LLMs (fill to enable the matching config.yaml route).
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# HUGEN_LOG_LEVEL=debug
