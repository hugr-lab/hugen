# tests/scenarios/.test.env.example — copy to .test.env and fill in.
# .test.env is gitignored.
#
# The harness (tests/scenarios/harness/Setup) loads this file before
# every run. Each `runs:` entry's `requires:` list maps to env-var
# names here (see tests/scenarios/harness/env.go::requireMap).
# Missing keys make the relevant runs t.Skip cleanly — empty
# .test.env is always safe.

# ── Cloud LLMs ──
# Set the keys for whichever runs you want to exercise. Other runs
# will skip with a clear "require X: KEY not set" message.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Local LLM (LM Studio / Ollama / vLLM with OpenAI-compatible API) ──
# Required for runs that select a local model (e.g. gemma4-26b-fast).
LLM_LOCAL_URL=http://host.docker.internal:1234/v1/chat/completions
EMBED_LOCAL_URL=http://host.docker.internal:1234/v1/embeddings

# ── Hugr endpoint ──
# HUGR_URL is the base URL of your hugr deployment. Required for
# any run with `requires: [hugr]`.
HUGR_URL=http://host.docker.internal:15004

# Token capture: run `make hugr-token` once. The OIDC browser flow
# completes interactively; cmd/hugen-test-token writes the captured
# fields back here. Refresh the file when scenarios start failing
# with token-expired errors (typically after the access-token TTL
# elapses — usually ~1h).
HUGR_DISCOVER_URL=http://host.docker.internal:15004
HUGR_ACCESS_TOKEN=
HUGR_REFRESH_TOKEN=
HUGR_TOKEN_EXPIRES_AT=

# ── Workspace + state paths ──
# Per-run dirs land under tests/scenarios/.data/run-<ts>/<run>/;
# these settings only affect the in-process bootstrap, not where
# the harness writes its own artefacts.
HUGEN_LOG_LEVEL=info
HUGEN_PYTHON_TEMPLATE=${HOME}/.hugen/python-template/.venv
HUGEN_SHARED_ROOT=${PWD}/data
